datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Game {
  id       Int    @id
  name     String
  platform String
}

model Trend {
  id          Int     @id
  word        String
  prediction  Float?
  growthRate  Float?
  acceleration Float?
  platformScore Float?
  aiScore      Float?
  firstSeenAt DateTime?
  platforms   String[]
}
