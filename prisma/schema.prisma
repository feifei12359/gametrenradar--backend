generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id     Int     @id @default(autoincrement())
  name   String
  trends Trend[]
}

model Trend {
  id               Int      @id @default(autoincrement())
  word             String
  prediction_score Float?
  growth_rate      Float?
  acceleration     Float?
  platform_score   Float?
  ai_score         Float?
  first_seen_at    DateTime?
  platforms        String[]
  category         String
  gameId           Int
  game             Game     @relation(fields: [gameId], references: [id])
}
