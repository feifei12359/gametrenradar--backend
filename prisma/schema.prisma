generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trend {
  id                  String   @id @default(cuid())
  keyword             String
  normalizedKeyword   String
  stage               String
  type                String?
  score               Float
  source              String?
  region              String?
  aiInsight           String?
  growthRate          Float?
  acceleration        Float?
  recentCount         Int?
  totalCount          Int?
  current24hCount     Int?
  previous24hCount    Int?
  robloxExists        Boolean? @default(false)
  discoverMatch       Boolean? @default(false)
  keywordQualityScore Float?
  growthScore         Float?
  robloxExistsScore   Float?
  discoverScore       Float?
  freshnessScore      Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([stage, score(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([normalizedKeyword])
  @@index([type])
}

model NewWord {
  id                String   @id @default(cuid())
  keyword           String
  normalizedKeyword String
  source            String?
  firstSeenAt       DateTime @default(now())
  score             Float
  region            String?
  status            String?  @default("new")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([firstSeenAt(sort: Desc)])
  @@index([normalizedKeyword])
  @@index([status])
  @@unique([keyword, source])
}

model JobRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
}
