datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Game {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  platform    String
  trendType   String
  firstSeenAt DateTime
}

model Trend {
  id          Int      @id @default(autoincrement())
  word        String
  trendType   String
  growthRate  Float?
  acceleration Float?
  platformScore Float?
  aiScore     Float?
  firstSeenAt DateTime?
  platforms   String[]
}

model NewWord {
  id          Int      @id @default(autoincrement())
  token       String
  noveltyScore Float?
  recentCount  Int?
  totalCount   Int?
  firstSeenAt DateTime?
}
